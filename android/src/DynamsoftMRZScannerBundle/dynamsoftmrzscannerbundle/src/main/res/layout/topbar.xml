<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/black">

    <ImageView
        android:id="@+id/iv_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:foreground="?attr/selectableItemBackground"
        android:padding="16dp"
        android:src="@drawable/ic_top_close" />

    <ImageView
        android:id="@+id/iv_toggle_vibrate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        android:paddingHorizontal="8dp"
        android:src="@drawable/toggle_vibrate"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/iv_toggle_audio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        android:paddingHorizontal="8dp"
        android:src="@drawable/toggle_audio"
        app:layout_constraintEnd_toStartOf="@id/iv_toggle_vibrate" />

    <FrameLayout
        android:id="@+id/divider"
        android:layout_width="25dp"
        android:layout_height="16dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/iv_toggle_audio"
        app:layout_constraintTop_toTopOf="parent" >
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.3"
            android:background="#FFFFFF"/>
    </FrameLayout>

    <ImageView
        android:id="@+id/iv_toggle_camera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        android:paddingHorizontal="8dp"
        android:src="@drawable/toggle_camera"
        app:layout_constraintEnd_toStartOf="@id/divider" />

    <ImageView
        android:id="@+id/iv_toggle_flashlight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        android:paddingHorizontal="8dp"
        android:src="@drawable/toggle_flashlight"
        app:layout_constraintEnd_toStartOf="@id/iv_toggle_camera" />

</androidx.constraintlayout.widget.ConstraintLayout>